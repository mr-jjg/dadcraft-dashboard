# default: 8081
PORT=8081

# required: set to your frontend origin
ALLOWED_ORIGIN=http://localhost:5173

# default: Docker service name
PROMETHEUS_URL=http://prometheus:9090/api/v1/

# default: /
DISK_MOUNTPOINT=/

# default: enp2s15
NETWORK_DEVICE=eth0

# required: MySQL DSN for game database
# TCP:  user:password@tcp(host:port)/dbname
# Unix: user:password@unix(/var/run/mysqld/mysqld.sock)/dbname
DB_DSN=user:password@unix(/var/run/mysqld/mysqld.sock)/dbname
